{
  "name": "resourcespace-mcp-server",
  "version": "1.1.0",
  "description": "Model Context Protocol server for ResourceSpace API integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "resourcespace-mcp-server": "dist/index.js",
    "resourcespace-admin-mcp": "dist/index-admin.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "QUICK_START.md",
    "INSTALLATION.md",
    "MULTI_SERVER_GUIDE.md",
    "API_MAPPING.md",
    "EXAMPLES.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "postinstall": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "resourcespace",
    "api",
    "dam",
    "digital-asset-management",
    "ai",
    "claude",
    "cursor",
    "llm",
    "typescript"
  ],
  "author": "Magnolia Tech Services",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magnolia-Tech-Services-LLC/ressourcespaceMCP.git"
  },
  "bugs": {
    "url": "https://github.com/Magnolia-Tech-Services-LLC/ressourcespaceMCP/issues"
  },
  "homepage": "https://github.com/Magnolia-Tech-Services-LLC/ressourcespaceMCP#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
